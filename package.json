{
  "name": "cleric-character-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && npm run copy-data",
    "copy-data": "cp -r public/data dist/ 2>/dev/null && cp -r public/images dist/ 2>/dev/null || echo 'Data/images copy done'",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "localforage": "^1.10.0",
    "lucide-react": "^0.300.0",
    "p5": "^2.2.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^20.0.0",
    "@types/p5": "^1.7.7",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^10.2.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.3.0",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^0.17.0",
    "vitest": "^1.3.0",
    "xlsx": "^0.18.0"
  }
}
